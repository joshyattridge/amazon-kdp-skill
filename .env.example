# Local KDP automation server
KDP_SERVER_PORT=3001
KDP_API_URL=http://localhost:3001

# Session + cache directory (Playwright cookies, metadata JSON)
KDP_SESSION_DIR=.kdp-session

# Delay between every KDP page load and API call (ms) — avoids Amazon "Server Busy"
# Legacy alias: KDP_UPDATE_DELAY_MS
KDP_REQUEST_DELAY_MS=4000
